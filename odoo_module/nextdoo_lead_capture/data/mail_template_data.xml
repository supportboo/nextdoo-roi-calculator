<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_lead_notification" model="mail.template">
        <field name="name">Nextdoo · Notificación lead magnet</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="subject">[Lead Magnet] {{ object.partner_name }} · {{ ctx.get('lead_source') }}</field>
        <field name="email_from">{{ object.team_id.alias_email or 'info@nextdoo.cloud' }}</field>
        <field name="email_to">{{ object.user_id.email or 'jeanlouis@nextdoo.cloud' }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html"><![CDATA[
<div style="font-family: 'Inter', Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #f7f7f8; padding: 0;">
  <div style="background: linear-gradient(135deg, #A855F7 0%, #EC4899 100%); padding: 24px; color: white;">
    <h1 style="margin: 0; font-size: 22px; font-weight: 800;">Nuevo lead capturado</h1>
    <p style="margin: 4px 0 0; opacity: 0.9; font-size: 14px;">Fuente: <strong t-out="ctx.get('lead_source') or '—'"/> · Urgencia: <strong t-out="ctx.get('lead_urgency') or '—'"/></p>
  </div>

  <div style="padding: 24px; background: white;">
    <h2 style="margin: 0 0 16px; color: #111; font-size: 18px;">
      <span t-out="object.partner_name or '—'"/>
    </h2>

    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tr><td style="padding: 8px 0; color: #6b7280;">Contacto</td><td style="padding: 8px 0;"><strong t-out="object.contact_name"/></td></tr>
      <tr><td style="padding: 8px 0; color: #6b7280;">Email</td><td style="padding: 8px 0;"><a t-att-href="'mailto:' + (object.email_from or '')" style="color: #A855F7;"><span t-out="object.email_from"/></a></td></tr>
      <tr><td style="padding: 8px 0; color: #6b7280;">Teléfono</td><td style="padding: 8px 0;"><a t-att-href="'tel:' + (object.phone or '')" style="color: #A855F7;"><span t-out="object.phone or '—'"/></a></td></tr>
      <tr><td style="padding: 8px 0; color: #6b7280;">Cargo</td><td style="padding: 8px 0;"><span t-out="object.function or '—'"/></td></tr>
      <tr><td style="padding: 8px 0; color: #6b7280;">Prioridad</td><td style="padding: 8px 0;"><span t-out="object.priority"/> ★</td></tr>
    </table>

    <div style="background: #f9fafb; border-left: 4px solid #A855F7; padding: 12px 16px; margin-top: 16px; font-family: monospace; white-space: pre-wrap; font-size: 12px; color: #374151;">
<t t-out="object.description"/>
    </div>

    <div style="margin-top: 24px; padding: 16px; background: #fef3c7; border-radius: 8px; color: #92400e; font-size: 14px;">
      <strong>Acción requerida HOY:</strong> contactar en menos de 24 horas. La actividad ya está creada en el lead.
    </div>

    <a t-att-href="'%s/odoo/action-crm.crm_lead_all_leads/%d' % (object.get_base_url(), object.id)"
       style="display: inline-block; background: linear-gradient(135deg, #A855F7, #EC4899); color: white; padding: 12px 24px; border-radius: 8px; text-decoration: none; font-weight: 700; margin-top: 16px; font-size: 14px;">
      Abrir lead en Odoo →
    </a>
  </div>

  <div style="padding: 16px 24px; background: #111; color: #9ca3af; font-size: 11px; text-align: center;">
    Nextdoo Cloud · Lead Magnet Engine · Generado automáticamente
  </div>
</div>
]]></field>
    </record>

</odoo>
